# Copy to .env.local for production form delivery.
# Where booking enquiries are emailed to:
GARAGE_BOOKING_EMAIL=bookings@superiorgarage.com.au

# Resend API key (recommended). Get one at https://resend.com
# If not set, the API logs the submission server-side and still returns success
# so the form can be demoed before email is wired up.
RESEND_API_KEY=

# Verified sender domain in Resend (e.g. notifications@yourdomain.com).
# Falls back to onboarding@resend.dev (Resend's test sender) if blank.
GARAGE_FROM_EMAIL=
